# ─────────────────────────────────────────────────────────────────────────────
# AcordosPRO — Variáveis de Ambiente
# ─────────────────────────────────────────────────────────────────────────────
# Copie este arquivo para .env.local e preencha com os valores do seu projeto Supabase.
# Nunca comite .env.local no repositório.
#
# Como obter os valores:
#   1. Acesse https://app.supabase.com e abra o seu projeto
#   2. Vá em Settings → API
#   3. Copie o "Project URL" e a "anon public" key
#
# ─────────────────────────────────────────────────────────────────────────────

# URL do projeto Supabase (obrigatório)
VITE_SUPABASE_URL=https://<seu-projeto>.supabase.co

# Chave pública anônima do Supabase (obrigatório)
VITE_SUPABASE_ANON_KEY=<sua-anon-key>

# ─── Variáveis opcionais de build ────────────────────────────────────────────

# Ativa/desativa mensagens de controle de rota via postMessage (padrão: true em dev)
# VITE_ENABLE_ROUTE_MESSAGING=false

# Prefixo CDN para imagens em produção (deixe em branco para usar /public)
# CDN_IMG_PREFIX=https://cdn.exemplo.com

# ─── Chaves de back-end (NUNCA exponha no frontend) ──────────────────────────
# As seguintes chaves são configuradas diretamente nos Secrets do Supabase
# e são acessadas exclusivamente pelas Edge Functions (Deno).
# NÃO adicione-as aqui — apenas como referência:
#
#   SUPABASE_SERVICE_ROLE_KEY=<sua-service-role-key>
#   OPENAI_API_KEY=<sua-openai-key>
